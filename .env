PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://auth_user:123456@localhost:5432/auth_db

# JWT secrets — use long, random, distinct values in production
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_a_different_64_char_random_hex

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
REFRESH_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=localhost

# bcrypt
BCRYPT_SALT_ROUNDS=12